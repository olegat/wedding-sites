#include "burger.css"
#include "fonts.css"
#include "language.css"
#include "stamp.css"

/* Reset some default styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --airmail-stripe-color1: #d22f47;
    --airmail-stripe-color2: #315f9b;
    --airmail-background: #eee6d3;
    --color-light: rgb(237, 232, 226);
    --color-mid: rgb(179, 178, 158);
    --color-dark: rgb(41, 55, 39);
    background: var(--color-mid);
}

.banner-section {
    background: var(--color-mid);
    display: flex;
    flex-direction: column;
    align-items: center;
}

@media (min-width: 769px) {
    .airmail {
        margin: 2rem;
        padding: 40px;
        aspect-ratio: 2.3 / 1;
        width: 85vw;

        border-image-source: repeating-linear-gradient(
            142deg,
            var(--airmail-stripe-color1) 0px 30px,
            transparent 30px 50px,
            var(--airmail-stripe-color2) 50px 80px,
            transparent 80px 100px
        );
        border-image-slice: 40;
        border-image-width: 40px;
        background-color: var(--airmail-background);
        box-shadow: 5px 5px 33px -1px rgba(0, 0, 0, 0.70);
    }

    .airmail > * {
        position: absolute;
    }

    .airmail .par-avion {
        color: var(--airmail-stripe-color2);
        font-family: 'Aileron Bold';
        font-size: 1.95vw;
        transform: translateX(1vw) translateY(1vw);
    }

    .airmail h1 {
        transform: translateX(17.63vw) translateY(6.7vw);
        font-family: 'New Icon Serif Regular';
        font-size: 8.5vw;
    }
    .airmail h1 > .line2 {
        display: inline-block;
        margin-left: 13.8vw;
        font-family: 'Pinyon Script';
    }

    .airmail .stamp-border {
        --stamp-border-radius: 0.25vw;
        width: 15vw;
        transform: translateX(62vw) translateY(2vw);
    }

    .airmail svg {
        width: 13vw;
        margin-top: 3.1vw;
    }
}

.banner-section > p {
    color: var(--color-dark);
    font-family: 'Aileron';
    font-size: 2em;
}
