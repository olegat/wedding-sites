<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mary & Oli Wedding</title>
    #include "favicon.html.in"
    <link rel="stylesheet" href="./index.css">
    <script src="./language.js"></script>
  </head>
  <body>
    #include "language.html.in"
    <section class="banner-section">
      <div class="section-column">
        <div class="section-row">
          <span class="banner-name">mary</span>
          <span lang="en" class="banner-conjunction">and</span>
          <span lang="es" class="banner-conjunction">y</span>
          <span lang="fr" class="banner-conjunction">et</span>
          <span class="banner-name">oli</span>
        </div>

        <div class="section-row">
          <div class="banner-image-triplet">
            <img src="./flowers1-dark.webp">
            <img src="./placeholder1.jpeg">
            <img src="./flowers1-dark.webp">
          </div>
        </div>

        <p class="banner-date" lang="en">Saturday 10th October 2026</p>
        <p class="banner-date" lang="es">Sábado 10 de Octubre de 2026</p>
        <p class="banner-date" lang="fr">Samedi 10 Octobre 2026</p>
        <p class="banner-location" lang="en">Zaragoza, Spain</p>
        <p class="banner-location" lang="es">Zaragoza, España</p>
        <p class="banner-location" lang="fr">Saragosse, Espagne</p>
      </div>
    </section>

    <section class="photo-section">
      <div class="section-content">
          <img src="placeholder2.jpeg">
      </div>
    </section>

    <section class="where-section">
      <div class="section-column">
        <div class="section-row where-row-p">
          <span lang="en">Zaragoza, Spain</span>
          <span lang="es">Zaragoza, España</span>
          <span lang="fr">Saragosse, Espagne</span>
        </div>
        <div class="section-row">
          <div class="stamp-border placeholder3-container">
            <img src="./placeholder3.jpeg">
          </div>
        </div>
        <div class="section-row where-row-title">
          <span lang="en">Venue</span>
          <span lang="es">Finca</span>
          <span lang="fr">Lieu</span>
        </div>
        <div class="section-row where-row-p">
          <span class="where-p" >Soto De Bruil</span>
        </div>
      </div>
    </section>

    <section class="schedule-section">
      <img src="placeholder4.jpeg">

      <div class="section-column">

        <div class="schedule-title">
          <div lang="en">
            <div class="wedding">Wedding</div><div class="program">program</div>
          </div>
          <div lang="es">
            <div class="program">programa de</div><div class="wedding">La Boba</div>
          </div>
          <div lang="fr">
            <div class="program">programme du</div><div class="wedding">Marriage</div>
          </div>
          <img src="flowers1-light.webp">
        </div>

        <ul class="schedule">
          <li>
            <time>12:00</time>
            <div lang="en">
              <strong>Shuttle Bus Departure</strong>
              <p>Pickup from Paraninfo in Zaragoza centre.</p>
            </div>
            <div lang="es">
              <strong>Salida del autobús</strong>
              <p>Recogida en el Paraninfo, en el centro de Zaragoza.</p>
            </div>
            <div lang="fr">
              <strong>Départ de la navette</strong>
              <p>Prise en charge au Paraninfo, dans le centre de Saragosse.</p>
            </div>
          </li>
          <li>
            <time>13:00</time>
            <div lang="en">
              <strong>Ceremony</strong>
              <p>Join Mary and Oli as they exchange their vows.</p>
            </div>
            <div lang="es">
              <strong>Ceremonia</strong>
              <p>Acompañad a Mary y Oli mientras intercambian sus votos.</p>
            </div>
            <div lang="fr">
              <strong>Cérémonie</strong>
              <p>Rejoignez Mary et Oli pour l’échange de leurs vœux.</p>
            </div>
          </li>
          <li>
            <time>14:00</time>
            <div lang="en">
              <strong>Cocktail</strong>
              <p>Enjoy drinks, appetizers, and jamón as we celebrate together.</p>
            </div>
            <div lang="es">
              <strong>Cóctel</strong>
              <p>Disfrutad de bebidas, aperitivos y jamón mientras celebramos juntos.</p>
            </div>
            <div lang="fr">
              <strong>Cocktail</strong>
              <p>Profitez de boissons, d’amuse-bouches et de jambon tout en célébrant ensemble.</p>
            </div>
          </li>
          <li>
            <time>18:00</time>
            <div lang="en">
              <strong>Dinner</strong>
              <p>A four-course meal to enjoy together.</p>
            </div>
            <div lang="es">
              <strong>Cena</strong>
              <p>Un menú de cuatro platos para disfrutar juntos.</p>
            </div>
            <div lang="fr">
              <strong>Dîner</strong>
              <p>Un repas en quatre plats à savourer ensemble.</p>
            </div>
          </li>
          <li>
            <time>20:00</time>
            <div lang="en">
              <strong>Reception</strong>
              <p>Time to celebrate—music, dancing, and drinks all night long.</p>
            </div>
            <div lang="es">
              <strong>Fiesta</strong>
              <p>¡Hora de celebrar! Música, baile y copas toda la noche.</p>
            </div>
            <div lang="fr">
              <strong>Soirée</strong>
              <p>Place à la fête : musique, danse et boissons toute la nuit.</p>
            </div>
          </li>
          <li>
            <time>00:05</time>
            <div lang="en">
              <strong>Shuttle Bus Return</strong>
              <p>Return to Zaragoza city centre.</p>
            </div>
            <div lang="es">
              <strong>Regreso en autobús</strong>
              <p>Vuelta al centro de Zaragoza.</p>
            </div>
            <div lang="fr">
              <strong>Retour en navette</strong>
              <p>Retour vers le centre de Saragosse.</p>
            </div>
          </li>
        </ul>
      </div>
    </section>
    <section class="rsvp-section">
      <div class="section-column">
        <div class="section-row">
          <div class="rsvp-triplet">
            <img src="./flowers3-dark.webp">
            <a href="#">R.S.V.P.</a>
            <img src="./flowers3-dark.webp">
          </div>
        </div>
      </div>
    </section>
  </body>
</html>

