<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mary & Oli Wedding</title>
    #include "favicon.html.in"
    <link rel="stylesheet" href="./index.css">
  </head>
  <body>
    <section class="banner-section">
      <div class="banner-text">
        <span class="banner-name">mary</span>
        <span class="banner-conjunction">and</span>
        <span class="banner-name">oli</span>
        <p class="banner-date">10 OCTOBER 2026</p>
      </div>
    </section>

    <section class="hero-section">
      <h2>Where?</h2>
      <p>Zaragoza, Spain</p>

      <h2>Venue</h2>
      <p>Soto De Bruil</p>
    </section>

    <section class="gray-bg">
      <h2>Schedule</h2>
      <div class="schedule">
        <p>12:00 Shuttle Bus Pickup from Zaragoza centre</p>
        <p>12:30 Arrival at Venue</p>
        <p>13:00 Ceremony</p>
        <p>14:00 PLACEHOLDER (schedule not complete yet)</p>
        <p>00:05 Shuttle Bus Return to Zaragoza centre</p>
      </div>
    </section>

    <section class="white-bg">
      <a href="#" class="rsvp-button">RSVP</a>
    </section>
  </body>
</html>

