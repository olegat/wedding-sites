#include "fonts.css"
#include "language.css"

#define SECTION_DEFAULTS()                   \
    display: flex;                           \
    align-items: center;                     \
    justify-content: center;                 \
    padding-top: var(--section-vpadding);    \
    padding-bottom: var(--section-vpadding); \
    text-align: center;                      \


:root {
    --color-light: rgb(237, 232, 226);
    --color-mid: rgb(179, 178, 158);
    --color-dark: rgb(41, 55, 39);
    --section-vpadding: 4em;
}

body {
    margin: 0;
}

.banner-section {
    SECTION_DEFAULTS();
    background: var(--color-mid);
    color: var(--color-dark);
}

.section-row {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: center;
    white-space: nowrap;
    max-width: 100vw;
}

.banner-name,
.banner-conjunction {
    display: inline-block;
    vertical-align: middle;
}

.banner-name {
    font-family: 'New Icon Serif Regular';
    font-size: clamp(2.5rem, 18vw, 14rem);
    padding-top: 0.22em;
}

.banner-conjunction {
    font-family: 'Pinyon Script';
    font-size: clamp(2rem, 12vw, 8rem);
    padding-left: 0.31em;
}

.banner-conjunction[lang="en"] {
    padding-right: 0.62em;
}

.banner-conjunction[lang="es"] {
    padding-right: 0.31em;
}

.banner-conjunction[lang="fr"] {
    padding-right: 0.50em;
}

.banner-image-triplet {
    position: relative;
    width: 100%;
    max-width: 100vw;
    aspect-ratio: 3 / 1;
    margin: 0 auto;
    --flower-scale: 0.7;
}

.banner-image-triplet img {
    position: absolute;
    width: auto;
    object-fit: contain;
}

.banner-image-triplet img:nth-child(1) {
    left: 0;
    transform: scale(1, -1) rotate(90deg);
}

.banner-image-triplet img:nth-child(2) {
    height: 100%;
    left: 50%;
    transform: translateX(-50%);
}

.banner-image-triplet img:nth-child(3) {
    right: 0;
    transform: rotate(-90deg);
}

/* scale the flowers on the side of picture of Mary & Oli by --flower-scale */
.banner-image-triplet img:nth-child(1),
.banner-image-triplet img:nth-child(3) {
    height: calc(var(--flower-scale) * 100%);
    top: calc((1 - var(--flower-scale)) * 50%);
}

.banner-date {
    font-family: 'Aileron Bold';
    font-size: clamp(1rem, 2vw, 1.5rem);
}

.banner-location {
    font-family: 'Aileron';
    font-size: clamp(1rem, 2vw, 1.5rem);
}

.photo-section {
    height: clamp(300px, 60vh, 800px);
    overflow: hidden;
}

.photo-section img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
}

.where-section {
    SECTION_DEFAULTS();
    background: var(--color-light);
    color: var(--color-dark);
}

.where-row-title {
    font-family: 'Pinyon Script';
    font-size: clamp(2rem, 12vw, 8rem);
    font-weight: normal;
    justify-content: left;
}

.where-row-p {
    font-family: 'New Icon Serif Regular';
    font-size: clamp(2rem, 12vw, 8rem);
}

/*
 * Source:
 *   https://freefrontend.com/css-borders/
 *   https://codepen.io/joshwcomeau/pen/VwRqQGP
 */
.stamp-border {
  /* Change this value to adjust the stamp perforation size: */
  --radius: 8px;
  padding: calc(var(--radius) * 2.5);
  padding-bottom: calc(var(--radius) * 2);

  background-image:
    radial-gradient(
      var(--radius),
      transparent 98%,
      white
    ),
    linear-gradient(white 0 0);
  background-repeat:
    round,
    no-repeat;
  background-position:
    calc(var(--radius) * -1.5) calc(var(--radius) * -1.5),
    50%;
  background-size:
    calc(var(--radius) * 3) calc(var(--radius) * 3),
    calc(100% - var(--radius) * 3) calc(100% - var(--radius) * 3);
}

.stamp-border > img {
    width: 100%;
}

.placeholder3-container {
    width: 45vw;
    margin-top: 1em;
    margin-bottom: 1em;
}

.schedule-section {
    SECTION_DEFAULTS();
    background: var(--color-dark);
    color: var(--color-mid);
}

.schedule {
    list-style: none;
    padding: 0;
}

.schedule li {
    display: grid;
    grid-template-columns: 100px 1fr;
    margin: 1em;
}

.schedule time {
    grid-column: 1;
}

.schedule div[lang] {
    grid-column: 2;
    margin: 0;
    text-align: left;
}
.schedule p {
    margin: 0;
}
