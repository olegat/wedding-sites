#include "fonts.css"
#include "language.css"

:root {
    --banner-bg: rgb(179, 178, 158);
    --where-bg: rgb(237, 232, 226);
    --text-fg: rgb(41, 55, 39);
}

body {
    margin: 0;
}

.banner-section {
    display: flex;
    align-items: center;
    background: var(--banner-bg);
    color: var(--text-fg);
    justify-content: center;
    padding-top: 4em;
    padding-bottom: 4em;
    text-align: center;
}

.section-row {
    display: flex;
    flex-wrap: nowrap;
    justify-content: center;
    align-items: center;
    white-space: nowrap;
    max-width: 100vw;
}

.banner-name,
.banner-conjunction {
    display: inline-block;
    vertical-align: middle;
}

.banner-name {
    font-family: 'New Icon Serif Regular';
    font-size: clamp(2.5rem, 18vw, 14rem);
    padding-top: 0.22em;
}

.banner-conjunction {
    font-family: 'Pinyon Script';
    font-size: clamp(2rem, 12vw, 8rem);
    padding-left: 0.31em;
}

.banner-conjunction[lang="en"] {
    padding-right: 0.62em;
}

.banner-conjunction[lang="es"] {
    padding-right: 0.31em;
}

.banner-conjunction[lang="fr"] {
    padding-right: 0.50em;
}

.banner-image-triplet {
    position: relative;
    width: 100%;
    max-width: 100vw;
    aspect-ratio: 3 / 1;
    margin: 0 auto;
    --flower-scale: 0.7;
}

.banner-image-triplet img {
    position: absolute;
    width: auto;
    object-fit: contain;
}

.banner-image-triplet img:nth-child(1) {
    left: 0;
    transform: scale(1, -1) rotate(90deg);
}

.banner-image-triplet img:nth-child(2) {
    height: 100%;
    left: 50%;
    transform: translateX(-50%);
}

.banner-image-triplet img:nth-child(3) {
    right: 0;
    transform: rotate(-90deg);
}

/* scale the flowers on the side of picture of Mary & Oli by --flower-scale */
.banner-image-triplet img:nth-child(1),
.banner-image-triplet img:nth-child(3) {
    height: calc(var(--flower-scale) * 100%);
    top: calc((1 - var(--flower-scale)) * 50%);
}

.banner-date {
    font-family: 'Aileron Bold';
    font-size: clamp(1rem, 2vw, 1.5rem);
}

.banner-location {
    font-family: 'Aileron';
    font-size: clamp(1rem, 2vw, 1.5rem);
}

.photo-section {
    height: clamp(300px, 60vh, 800px);
    overflow: hidden;
}

.photo-section img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
}

.where-section {
    display: flex;
    align-items: center;
    background: var(--where-bg);
    color: var(--text-fg);
    justify-content: center;
}

.where-title {
    font-family: 'Pinyon Script';
    font-size: clamp(2rem, 12vw, 8rem);
    font-weight: normal;
}

.where-p {
    font-family: 'New Icon Serif Regular';
    font-size: clamp(2rem, 12vw, 8rem);
}
