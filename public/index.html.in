<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mary & Oli Wedding</title>
    #include "favicon.html.in"
    <link rel="stylesheet" href="./index.css">
    <script src="./language.js"></script>
  </head>
  <body>
    #include "language.html.in"
    <section class="banner-section">
      <div class="section-content">
        <div class="section-row">
          <span class="banner-name">mary</span>
          <span lang="en" class="banner-conjunction">and</span>
          <span lang="es" class="banner-conjunction">y</span>
          <span lang="fr" class="banner-conjunction">et</span>
          <span class="banner-name">oli</span>
        </div>

        <div class="section-row">
          <div class="banner-image-triplet">
            <img src="./flowers1.webp">
            <img src="./placeholder1.jpeg">
            <img src="./flowers1.webp">
          </div>
        </div>

        <p>
          <span class="banner-date" lang="en">10<sup>th</sup> OCTOBER 2026</span>
          <span class="banner-date" lang="es">10 de OCTUBRE de 2026</span>
          <span class="banner-date" lang="fr">10 OCTOBRE 2026</span>
          <span class="banner-location" lang="en">| ZARAGOZA, SPAIN</span>
          <span class="banner-location" lang="es">| ZARAGOZA, ESPAÑA</span>
          <span class="banner-location" lang="fr">| SARAGOSSE, ESPAGNE</span>
        </p>
      </div>
    </section>

    <section class="photo-section">
      <div class="section-content">
          <img src="placeholder2.jpeg">
      </div>
    </section>

    <section class="hero-section">
      <h2>Where?</h2>
      <p>Zaragoza, Spain</p>

      <h2>Venue</h2>
      <p>Soto De Bruil</p>
    </section>

    <section class="gray-bg">
      <h2>Schedule</h2>
      <div class="schedule">
        <p>12:00 Shuttle Bus Pickup from Zaragoza centre</p>
        <p>12:30 Arrival at Venue</p>
        <p>13:00 Ceremony</p>
        <p>14:00 PLACEHOLDER (schedule not complete yet)</p>
        <p>00:05 Shuttle Bus Return to Zaragoza centre</p>
      </div>
    </section>

    <section class="white-bg">
      <a href="#" class="rsvp-button">RSVP</a>
    </section>
  </body>
</html>

