#include "fonts.css"
#include "language.css"

:root {
    --banner-bg: rgb(179, 178, 158);
    --text-fg: rgb(41, 55, 39);
}

body {
    margin: 0;
}

.banner-section {
    display: flex;
    align-items: center;
    background: var(--banner-bg);
    color: var(--text-fg);
    justify-content: center;
    padding-top: 4em;
    padding-bottom: 4em;
    text-align: center;
}

.banner-name,
.banner-conjunction {
    display: inline-block;
    vertical-align: middle;
}

.banner-name {
    font-family: 'New Icon Serif Regular';
    font-size: clamp(5rem, 18vw, 14rem);
    padding-top: 0.22em;
}

.banner-conjunction {
    font-family: 'Pinyon Script';
    font-size: clamp(4rem, 12vw, 8rem);
    padding-left: 0.31em;
}

.banner-conjunction[lang="en"] {
    padding-right: 0.62em;
}

.banner-conjunction[lang="es"] {
    padding-right: 0.31em;
}

.banner-conjunction[lang="fr"] {
    padding-right: 0.50em;
}

.banner-date {
    font-family: 'Aileron Bold';
    font-size: clamp(1rem, 2vw, 1.5rem);
}

.banner-location {
    font-family: 'Aileron';
    font-size: clamp(1rem, 2vw, 1.5rem);
}
