#include "fonts.css"

:root {
    --banner-bg: rgb(179, 178, 158);
    --text-fg: rgb(41, 55, 39);
}

body {
    margin: 0;
}

.banner-section {
    align-items: center;
    background: var(--banner-bg);
    color: var(--text-fg);
    display: flex;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
}


.banner-name {
    font-family: 'New Icon Serif Regular';
}

.banner-conjunction {
    font-family: 'Pinyon Script';
}

.banner-date {
    font-family: 'Aileron Bold';
}

.banner-name {
    font-family: 'New Icon Serif Regular';
    font-size: clamp(3rem, 10vw, 8rem);
}

.banner-conjunction {
    font-family: 'Pinyon Script';
    font-size: clamp(2rem, 6vw, 4rem);
}

.banner-date {
    font-family: 'Aileron Bold';
    font-size: clamp(1rem, 2vw, 1.5rem);
}
