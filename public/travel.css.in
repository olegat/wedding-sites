#include "burger.css"
#include "fonts.css"
#include "language.css"
#include "stamp.css"
#include "airmail.css"

/* Reset some default styles */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --airmail-stripe-color1: #d22f47;
    --airmail-stripe-color2: #315f9b;
    --airmail-background: #eee6d3;
    --color-light: rgb(237, 232, 226);
    --color-mid: rgb(179, 178, 158);
    --color-dark: rgb(41, 55, 39);
    background: var(--color-mid);
}

.banner-section {
    background: var(--color-mid);
    display: flex;
    flex-direction: column;
    align-items: center;
}

/* Airmail defaults */
.airmail > * {
    position: absolute;
}

.airmail .par-avion {
    color: var(--airmail-stripe-color2);
    font-family: 'Aileron Bold';
    font-size: 1.95vw;
    transform: translateX(1vw) translateY(1vw);
}

.airmail h1 {
    transform: translateX(17.63vw) translateY(6.7vw);
    font-family: 'New Icon Serif Regular';
    font-size: 8.5vw;
}
.airmail h1 > .line2 {
    display: inline-block;
    margin-left: 13.8vw;
    font-family: 'Pinyon Script';
}

.airmail .stamp-border {
    --stamp-border-radius: 0.25vw;
    width: 15vw;
    transform: translateX(62vw) translateY(2vw);
}

.airmail svg {
    width: 13vw;
    margin-top: 3.1vw;
}

/* Desktop (low-res) */
@media (max-width: 1200px) {
    .airmail {
        --airmail-stripe-slice: 20;
    }
}

/* Mobile */
@media (max-width: 769px) {
    .airmail {
        --airmail-stripe-slice: 10;
        aspect-ratio: 1.7 / 1;
    }

    .airmail h1 {
        transform: translateX(17.63vw) translateY(10vw);
        font-size: 10.2vw;
    }
}

.banner-section > p {
    color: var(--color-dark);
    font-family: 'Aileron';
    font-size: 2em;
}
