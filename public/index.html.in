<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mary & Oli Wedding</title>
    #include "favicon.html.in"
    <link rel="stylesheet" href="./index.css">
    <script src="./language.js"></script>
  </head>
  <body>
    #include "language.html.in"
    <section class="banner-section">
      <div class="banner-text">
        <div class="banner-names">
          <span class="banner-name">mary</span>
          <span lang="en" class="banner-conjunction">and</span>
          <span lang="es" class="banner-conjunction">y</span>
          <span lang="fr" class="banner-conjunction">et</span>
          <span class="banner-name">oli</span>
        </div>

        <img
          src="./flowers1.webp"
          style="width:250px; height:auto; transform: scale(1, -1) rotate(90deg)"
          >
        <img
          src="./placeholder.jpeg"
          width="508"
          height="323"
          >
        <img
          src="./flowers1.webp"
          style="width:250px; height:auto; transform: rotate(-90deg)"
          >

        <p class="banner-date" lang="en">Saturday 10th October 2026</p>
        <p class="banner-date" lang="es">Sábado 10 de Octubre de 2026</p>
        <p class="banner-date" lang="fr">Samedi 10 Octobre 2026</p>
        <p class="banner-location" lang="en">Zaragoza, Spain</p>
        <p class="banner-location" lang="es">Zaragoza, España</p>
        <p class="banner-location" lang="fr">Saragosse, Espagne</p>
      </div>
    </section>

    <section class="hero-section">
      <h2>Where?</h2>
      <p>Zaragoza, Spain</p>

      <h2>Venue</h2>
      <p>Soto De Bruil</p>
    </section>

    <section class="gray-bg">
      <h2>Schedule</h2>
      <div class="schedule">
        <p>12:00 Shuttle Bus Pickup from Zaragoza centre</p>
        <p>12:30 Arrival at Venue</p>
        <p>13:00 Ceremony</p>
        <p>14:00 PLACEHOLDER (schedule not complete yet)</p>
        <p>00:05 Shuttle Bus Return to Zaragoza centre</p>
      </div>
    </section>

    <section class="white-bg">
      <a href="#" class="rsvp-button">RSVP</a>
    </section>
  </body>
</html>

