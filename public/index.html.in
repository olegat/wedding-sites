<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mary & Oli Wedding</title>
    #include "favicon.html.in"
    <link rel="stylesheet" href="./index.css">
    <script src="./language.js"></script>
  </head>
  <body>
    #include "language.html.in"
    <section class="banner-section">
      <div class="section-column">
        <div class="section-row">
          <span class="banner-name">mary</span>
          <span lang="en" class="banner-conjunction">and</span>
          <span lang="es" class="banner-conjunction">y</span>
          <span lang="fr" class="banner-conjunction">et</span>
          <span class="banner-name">oli</span>
        </div>

        <div class="section-row">
          <div class="banner-image-triplet">
            <img src="./flowers1.webp">
            <img src="./placeholder1.jpeg">
            <img src="./flowers1.webp">
          </div>
        </div>

        <p class="banner-date" lang="en">Saturday 10th October 2026</p>
        <p class="banner-date" lang="es">Sábado 10 de Octubre de 2026</p>
        <p class="banner-date" lang="fr">Samedi 10 Octobre 2026</p>
        <p class="banner-location" lang="en">Zaragoza, Spain</p>
        <p class="banner-location" lang="es">Zaragoza, España</p>
        <p class="banner-location" lang="fr">Saragosse, Espagne</p>
      </div>
    </section>

    <section class="photo-section">
      <div class="section-content">
          <img src="placeholder2.jpeg">
      </div>
    </section>

    <section class="where-section">
      <div class="section-column">
        <div class="section-row where-row-p">
          <span lang="en">Zaragoza, Spain</span>
          <span lang="es">Zaragoza, España</span>
          <span lang="fr">Saragosse, Espagne</span>
        </div>
        <div class="section-row">
          <div class="stamp-border placeholder3-container">
            <img src="./placeholder3.jpeg">
          </div>
        </div>
        <div class="section-row where-row-title">
          <span lang="en">Venue</span>
          <span lang="es">Finca</span>
          <span lang="fr">Lieu</span>
        </div>
        <div class="section-row where-row-p">
          <span class="where-p" >Soto De Bruil</span>
        </div>
      </div>
    </section>

    <section class="schedule-section">
      <div class="section-column">
        <img src="placeholder4.jpeg" style="width: 30vw">
      </div>
      <div class="section-column">
        <h2>Schedule</h2>
        <ul class="schedule">
          <li>
            <time>12:00</time>
            <div lang="en">
              <strong>Shuttle Bus Departure</strong>
              <p>Pickup from Paraninfo in Zaragoza centre.</p>
            </div>
            <div lang="es">
              <strong>PLACEHOLDER</strong>
              <p>PLACEHOLDER</p>
            </div>
            <div lang="fr">
              <strong>PLACEHOLDER</strong>
              <p>PLACEHOLDER.</p>
            </div>
          </li>
          <li>
            <time>13:00</time>
            <div lang="en">
              <strong>Ceremony</strong>
              <p>Join Mary and Oli as they exchange their vows.</p>
            </div>
            <div lang="es">
              <strong>PLACEHOLDER</strong>
              <p>PLACEHOLDER</p>
            </div>
            <div lang="fr">
              <strong>PLACEHOLDER</strong>
              <p>PLACEHOLDER.</p>
            </div>
          </li>
          <li>
            <time>14:00</time>
            <div lang="en">
              <strong>Cocktail</strong>
              <p>PLACEHOLDER (in spain, they serve drinks, appertizers, and jamon at this part).</p>
            </div>
            <div lang="es">
              <strong>PLACEHOLDER</strong>
              <p>PLACEHOLDER</p>
            </div>
            <div lang="fr">
              <strong>PLACEHOLDER</strong>
              <p>PLACEHOLDER.</p>
            </div>
          </li>
          <li>
            <time>18:00</time>
            <div lang="en">
              <strong>Dinner</strong>
              <p>PLACEHOLDER (you get the gist, four-course meal, yum yum).</p>
            </div>
            <div lang="es">
              <strong>PLACEHOLDER</strong>
              <p>PLACEHOLDER</p>
            </div>
            <div lang="fr">
              <strong>PLACEHOLDER</strong>
              <p>PLACEHOLDER.</p>
            </div>
          </li>
          <li>
            <time>20:00</time>
            <div lang="en">
              <strong>Reception</strong>
              <p>PLACEHOLDER (party time, dance drink and party all night long).</p>
            </div>
          </li>
          <li>
            <time>00:05</time>
            <div lang="en">
              <strong>Shuttle Bus Return</strong>
              <p>PLACEHOLDER (back to Zaragoza city-centre).</p>
            </div>
            <div lang="es">
              <strong>PLACEHOLDER</strong>
              <p>PLACEHOLDER</p>
            </div>
            <div lang="fr">
              <strong>PLACEHOLDER</strong>
              <p>PLACEHOLDER.</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <section class="white-bg">
      <a href="#" class="rsvp-button">RSVP</a>
    </section>
  </body>
</html>

